# Backend production environment — copy values into your host's secret store.
# Never commit the real .env.production (already covered by .gitignore).

# Postgres connection string from your managed DB (Neon / Render / Railway / Supabase)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# TLS to the database. 'require' for Neon/Render/Supabase. Leave UNSET on Railway
# (its private network doesn't use TLS).
DATABASE_SSL=require

NODE_ENV=production
LOG_LEVEL=info
# PORT is injected by Render/Railway — only set it on a bare VPS.

# Strong random secrets — generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_32+_RANDOM_BYTES
PLATFORM_ADMIN_KEY=REPLACE_WITH_32+_RANDOM_BYTES

# Comma-separated allowed origins for CORS — both frontends, https, no trailing slash
FRONTEND_URL=https://app.yourdomain.com,https://3d.yourdomain.com
